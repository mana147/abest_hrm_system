<!-- Page header -->
<div class="d-flex justify-content-between align-items-start mb-4">
  <div class="page-header mb-0">
    <div class="page-title"><%= t('courses.title') %></div>
    <div class="page-sub"><%= total %> <%= lang==='vi' ? 'khóa học' : 'courses' %></div>
  </div>
  <a href="/courses/new" class="btn btn-primary">
    <i class="bi bi-plus-circle me-2"></i><%= t('courses.add') %>
  </a>
</div>

<!-- Search + Filter bar -->
<form method="GET" action="/courses" class="mb-4">
  <div class="d-flex gap-2 flex-wrap">
    <div class="input-group" style="max-width:320px">
      <span class="input-group-text bg-white border-end-0" style="border-color:var(--hairline)">
        <i class="bi bi-search text-muted"></i>
      </span>
      <input type="text" name="search" class="form-control border-start-0 ps-0"
             style="border-color:var(--hairline)"
             placeholder="<%= lang==='vi' ? 'Tìm tên, mã khóa học...' : 'Search name, code...' %>"
             value="<%= search %>">
    </div>

    <select name="level" class="form-select" style="width:auto;min-width:180px"
            onchange="this.form.submit()">
      <option value=""><%= lang==='vi' ? 'Tất cả cấp độ' : 'All levels' %></option>
      <% [
        ['beginner',           lang==='vi' ? 'Beginner'           : 'Beginner'],
        ['elementary',         lang==='vi' ? 'Elementary'         : 'Elementary'],
        ['pre_intermediate',   lang==='vi' ? 'Pre-Intermediate'   : 'Pre-Intermediate'],
        ['intermediate',       lang==='vi' ? 'Intermediate'       : 'Intermediate'],
        ['upper_intermediate', lang==='vi' ? 'Upper-Intermediate' : 'Upper-Intermediate'],
        ['advanced',           lang==='vi' ? 'Advanced'           : 'Advanced'],
      ].forEach(([val, lbl]) => { %>
        <option value="<%= val %>" <%= filterLevel===val ? 'selected' : '' %>><%= lbl %></option>
      <% }) %>
    </select>

    <select name="status" class="form-select" style="width:auto;min-width:160px"
            onchange="this.form.submit()">
      <option value=""><%= lang==='vi' ? 'Tất cả trạng thái' : 'All status' %></option>
      <option value="active"   <%= filterStatus==='active'   ? 'selected' : '' %>>
        <%= lang==='vi' ? '✓ Đang dạy' : '✓ Active' %>
      </option>
      <option value="inactive" <%= filterStatus==='inactive' ? 'selected' : '' %>>
        <%= lang==='vi' ? '— Ngừng' : '— Inactive' %>
      </option>
    </select>

    <% if (search || filterLevel || filterStatus) { %>
      <a href="/courses" class="btn btn-outline-secondary">
        <i class="bi bi-x me-1"></i><%= lang==='vi' ? 'Xóa bộ lọc' : 'Clear' %>
      </a>
    <% } %>

    <button type="submit" class="btn btn-primary">
      <%= lang==='vi' ? 'Tìm' : 'Search' %>
    </button>
  </div>
</form>

<!-- Table -->
<div class="card p-0">
  <% if (rows.length === 0) { %>
    <div class="text-center py-5">
      <i class="bi bi-journal-bookmark" style="font-size:40px;color:var(--stone)"></i>
      <p class="mt-3 text-muted"><%= t('common.no_data') %></p>
      <a href="/courses/new" class="btn btn-primary btn-sm mt-1">
        <i class="bi bi-plus-circle me-1"></i><%= t('courses.add') %>
      </a>
    </div>
  <% } else { %>
  <div class="table-responsive">
    <table class="table mb-0">
      <thead>
        <tr>
          <th><%= t('courses.code') %></th>
          <th><%= t('courses.name') %></th>
          <th><%= t('courses.level') %></th>
          <th><%= t('courses.sessions') %></th>
          <th><%= t('courses.duration') %></th>
          <th><%= t('courses.fee') %></th>
          <th><%= t('common.status') %></th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% rows.forEach(c => { %>
        <tr>
          <td>
            <code style="font-size:12px;color:var(--ash)"><%= c.course_code %></code>
          </td>
          <td>
            <a href="/courses/<%= c.id %>" class="fw-semibold text-decoration-none" style="color:var(--ink)">
              <%= c.course_name %>
            </a>
          </td>
          <td style="color:var(--ash)"><%= c.level || '—' %></td>
          <td style="color:var(--ash)"><%= c.total_sessions %> <%= lang==='vi' ? 'buổi' : 'sessions' %></td>
          <td style="color:var(--ash)"><%= c.session_duration_minutes %> phút</td>
          <td style="color:var(--ink);font-weight:500">
            <%= Number(c.tuition_fee).toLocaleString('vi-VN') %> ₫
          </td>
          <td>
            <% const b = c.status==='active'
              ? { cls:'badge-active',   lbl: lang==='vi' ? 'Đang dạy' : 'Active' }
              : { cls:'badge-inactive', lbl: lang==='vi' ? 'Ngừng'    : 'Inactive' }; %>
            <span class="badge <%= b.cls %>" style="padding:4px 10px"><%= b.lbl %></span>
          </td>
          <td class="text-end">
            <div class="d-flex justify-content-end gap-1">
              <a href="/courses/<%= c.id %>"
                 class="btn btn-sm btn-outline-secondary" title="<%= lang==='vi' ? 'Xem' : 'View' %>">
                <i class="bi bi-eye"></i>
              </a>
              <a href="/courses/<%= c.id %>/edit"
                 class="btn btn-sm btn-outline-secondary" title="<%= t('common.edit') %>">
                <i class="bi bi-pencil"></i>
              </a>
            </div>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
  <% } %>
</div>

<!-- Pagination -->
<% if (totalPages > 1) { %>
<nav class="d-flex justify-content-between align-items-center mt-4">
  <span class="small text-muted">
    <%= lang==='vi'
      ? `Trang ${page} / ${totalPages} — ${total} khóa học`
      : `Page ${page} of ${totalPages} — ${total} courses` %>
  </span>
  <ul class="pagination pagination-sm mb-0">
    <li class="page-item <%= page<=1 ? 'disabled' : '' %>">
      <a class="page-link"
         href="?page=<%= page-1 %>&search=<%= search %>&level=<%= filterLevel %>&status=<%= filterStatus %>">
        <i class="bi bi-chevron-left"></i>
      </a>
    </li>
    <% for(let p=Math.max(1,page-2); p<=Math.min(totalPages,page+2); p++) { %>
      <li class="page-item <%= p===page ? 'active' : '' %>">
        <a class="page-link"
           href="?page=<%= p %>&search=<%= search %>&level=<%= filterLevel %>&status=<%= filterStatus %>">
          <%= p %>
        </a>
      </li>
    <% } %>
    <li class="page-item <%= page>=totalPages ? 'disabled' : '' %>">
      <a class="page-link"
         href="?page=<%= page+1 %>&search=<%= search %>&level=<%= filterLevel %>&status=<%= filterStatus %>">
        <i class="bi bi-chevron-right"></i>
      </a>
    </li>
  </ul>
</nav>
<% } %>

<style>
.page-link { border-color: var(--hairline); color: var(--ink); font-size:13px }
.page-item.active .page-link { background: var(--rausch); border-color: var(--rausch); }
</style>
