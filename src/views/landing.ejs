<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script>

window.addEventListener('scroll', () => {
  document.getElementById('lpNav').classList.toggle('scrolled', window.scrollY > 40);
});

function handleContact(e) {
  e.preventDefault();
  alert('<%= lang==="vi" ? "Đã nhận thông tin! Chúng tôi sẽ liên hệ trong vòng 30 phút." : "Received! We will contact you within 30 minutes." %>');
  e.target.reset();
}

document.addEventListener('DOMContentLoaded', () => {
  const mobileMenu = document.getElementById('lpMobileMenu');
  if (!mobileMenu || typeof bootstrap === 'undefined') return;

  document.querySelectorAll('.lp-mobile-menu a').forEach(link => {
    link.addEventListener('click', () => {
      if (mobileMenu.classList.contains('show')) {
        new bootstrap.Collapse(mobileMenu).hide();
      }
    });
  });
});


document.querySelectorAll('a[href^="#"]').forEach(a => {
  a.addEventListener('click', e => {
    const target = document.querySelector(a.getAttribute('href'));
    if (target) { e.preventDefault(); target.scrollIntoView({ behavior:'smooth', block:'start' }); }
  });
});
</script>
