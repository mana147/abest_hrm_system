<!DOCTYPE html>
<html lang="<%= lang %>">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= lang==='vi' ? 'ABest English Center — Trung tâm Anh ngữ ABest' : 'ABest English Center' %></title>
  <meta name="description" content="<%= lang==='vi' ? 'ABest tập trung vào TOEIC & IELTS với lộ trình đạt điểm cao, giáo viên chuyên sâu và cam kết đầu ra.' : 'ABest is dedicated to TOEIC & IELTS with expert coaching, proven paths, and performance commitment.' %>">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="preload" href="/images/logo.svg" as="image" type="image/svg+xml">
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;600;700&family=Manrope:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
  <link href="/css/landing.css" rel="stylesheet">
</head>
<body>

<!-- ── NAVBAR ─────────────────────────────────────────────── -->
<nav class="lp-nav" id="lpNav">
  <div class="lp-nav-inner">
    <a href="/" class="lp-logo">
      <img class="lp-logo-icon" src="/images/logo.svg" width="48" height="48" alt="ABest logo">
      <span class="lp-logo-text"> ABest </span>
      <span class="lp-logo-tagline">Excellence in Language</span>
    </a>

    <button class="lp-nav-toggle d-lg-none" type="button" data-bs-toggle="collapse" data-bs-target="#lpMobileMenu" aria-controls="lpMobileMenu" aria-expanded="false" aria-label="Toggle navigation">
      <svg width="24" height="24" viewBox="0 0 24 24" aria-hidden="true" focusable="false" xmlns="http://www.w3.org/2000/svg">
        <path d="M5 7h14M5 12h14M5 17h14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
      </svg>
    </button>

    <ul class="lp-nav-links">
      <li><a href="#courses"><%= lang==='vi' ? 'Khóa học' : 'Courses' %></a></li>
      <li><a href="#why"><%= lang==='vi' ? 'Tại sao ABest?' : 'Why ABest?' %></a></li>
      <li><a href="#teachers"><%= lang==='vi' ? 'Giáo viên' : 'Teachers' %></a></li>
      <li><a href="#contact"><%= lang==='vi' ? 'Liên hệ' : 'Contact' %></a></li>
    </ul>

    <div class="lp-nav-actions d-flex align-items-center gap-2">
      <div class="lp-lang-group">
        <a href="/language/vi" class="lp-lang-btn <%= lang==='vi' ? 'active' : '' %>">VI</a>
        <a href="/language/en" class="lp-lang-btn <%= lang==='en' ? 'active' : '' %>">EN</a>
      </div>
      <a href="/auth/login" class="lp-btn-ghost d-none d-md-inline-flex">
        <%= lang==='vi' ? 'Đăng nhập' : 'Login' %>
      </a>
    </div>
  </div>

  <div class="lp-mobile-menu collapse" id="lpMobileMenu">
    <ul class="lp-nav-links-mobile">
      <li><a href="#courses"><%= lang==='vi' ? 'Khóa học' : 'Courses' %></a></li>
      <li><a href="#why"><%= lang==='vi' ? 'Tại sao ABest?' : 'Why ABest?' %></a></li>
      <li><a href="#teachers"><%= lang==='vi' ? 'Giáo viên' : 'Teachers' %></a></li>
      <li><a href="#contact"><%= lang==='vi' ? 'Liên hệ' : 'Contact' %></a></li>
    </ul>
    <div class="lp-mobile-actions">
      <div class="lp-lang-group">
        <a href="/language/vi" class="lp-lang-btn <%= lang==='vi' ? 'active' : '' %>">VI</a>
        <a href="/language/en" class="lp-lang-btn <%= lang==='en' ? 'active' : '' %>">EN</a>
      </div>
      <div class="lp-mobile-buttons">
        <a href="/auth/login" class="lp-btn-ghost"> <%= lang==='vi' ? 'Đăng nhập' : 'Login' %> </a>
      </div>
    </div>
  </div>
</nav>

<!-- ── HERO ───────────────────────────────────────────────── -->
<section class="lp-hero">
  <div class="lp-hero-bg">
    <!-- gradient overlay -->
    <div class="lp-hero-overlay"></div>
    <!-- decorative circles -->
    <div class="lp-circle lp-circle-1"></div>
    <div class="lp-circle lp-circle-2"></div>
  </div>

  <div class="lp-hero-content container">
    <div class="lp-hero-badge">
      <i class="bi bi-star-fill me-1" style="color:var(--gold-light)"></i>
      <%= lang==='vi' ? 'Hơn 2.000 học viên tin tưởng' : 'Trusted by 2,000+ students' %>
    </div>
    <h1 class="lp-hero-title">
      <% if (lang==='vi') { %>
        Chinh phục TOEIC · IELTS<br><span class="lp-accent">bởi đội ngũ chuyên sâu</span>,<br>mỗi điểm số là một bước tiến mới
      <% } else { %>
        Own TOEIC · IELTS<br>with <span class="lp-accent">specialised coaching</span>,<br>every score unlocks your next success
      <% } %>
    </h1>
    <p class="lp-hero-sub">
      <% if (lang==='vi') { %>
        Chỉ tập trung vào TOEIC và IELTS<br>
        Lộ trình tập trung, giảng dạy chuyên sâu, cam kết nâng tầm kết quả.
      <% } else { %>
        Focused only on TOEIC and IELTS<br>
        Targeted pathways, intensive teaching, and a promise to raise your results.
      <% } %>
    </p>
    <div class="lp-hero-actions">
      <a href="#courses" class="lp-btn-primary lp-btn-lg">
        <i class="bi bi-grid me-2"></i><%= lang==='vi' ? 'Xem khóa học' : 'Browse Courses' %>
      </a>
      <a href="#contact" class="lp-btn-secondary lp-btn-lg">
        <%= lang==='vi' ? 'Tư vấn miễn phí' : 'Free Consultation' %>
        <i class="bi bi-arrow-right ms-2"></i>
      </a>
    </div>

    <!-- Stats row -->
    <div class="lp-stats">
      <div class="lp-stat">
        <span class="lp-stat-num">2,000+</span>
        <span class="lp-stat-lbl"><%= lang==='vi' ? 'Học viên' : 'Students' %></span>
      </div>
      <div class="lp-stat-divider"></div>
      <div class="lp-stat">
        <span class="lp-stat-num">95%</span>
        <span class="lp-stat-lbl"><%= lang==='vi' ? 'Đạt mục tiêu' : 'Goal achieved' %></span>
      </div>
      <div class="lp-stat-divider"></div>
      <div class="lp-stat">
        <span class="lp-stat-num">15+</span>
        <span class="lp-stat-lbl"><%= lang==='vi' ? 'Giáo viên' : 'Teachers' %></span>
      </div>
      <div class="lp-stat-divider"></div>
      <div class="lp-stat">
        <span class="lp-stat-num">8</span>
        <span class="lp-stat-lbl"><%= lang==='vi' ? 'Năm kinh nghiệm' : 'Years exp.' %></span>
      </div>
    </div>
  </div>
</section>

<!-- ── COURSES ─────────────────────────────────────────────── -->
<section class="lp-section" id="courses">
  <div class="container">
    <div class="lp-section-header">
      <p class="lp-section-eyebrow"><%= lang==='vi' ? 'Chương trình học' : 'Programs' %></p>
      <h2 class="lp-section-title">
        <%= lang==='vi' ? 'Khóa học phù hợp mọi mục tiêu' : 'Courses for every goal' %>
      </h2>
      <p class="lp-section-sub">
        <%= lang==='vi'
          ? 'Từ người mới bắt đầu đến luyện thi chuyên sâu — ABest có lộ trình phù hợp với bạn.'
          : 'From absolute beginner to exam prep — ABest has the right path for you.' %>
      </p>
    </div>

    <div class="lp-courses-grid">
      <% const courses = [
        { icon:'bi-bar-chart-fill', color:'#ff385c', bg:'#fff0f3',
          name: lang==='vi' ? 'TOEIC Foundation' : 'TOEIC Foundation',
          level: lang==='vi' ? 'Sơ - Trung cấp' : 'Elementary',
          sessions: 24, fee:'3,500,000',
          desc: lang==='vi' ? 'Nền tảng vững chắc cho kỳ thi TOEIC. Từ 400 → 650+.' : 'Build a solid foundation for TOEIC 400 → 650+.' },
        { icon:'bi-graph-up-arrow', color:'#2563eb', bg:'#eff6ff',
          name:'TOEIC Advanced',
          level: lang==='vi' ? 'Trung - Cao cấp' : 'Intermediate+',
          sessions: 24, fee:'4,000,000',
          desc: lang==='vi' ? 'Chinh phục TOEIC 750+. Kỹ năng thi chuyên sâu.' : 'Conquer TOEIC 750+. Advanced test strategies.' },
        { icon:'bi-globe2', color:'#059669', bg:'#f0fff4',
          name:'IELTS Pre',
          level: lang==='vi' ? 'Pre-Intermediate' : 'Pre-Intermediate',
          sessions: 30, fee:'4,500,000',
          desc: lang==='vi' ? 'Xây nền cho IELTS 5.0–5.5. Cả 4 kỹ năng.' : 'Build to IELTS 5.0–5.5 across all 4 skills.' },
        { icon:'bi-trophy-fill', color:'#7c3aed', bg:'#f5f3ff',
          name:'IELTS Intermediate',
          level: lang==='vi' ? 'Trung cấp' : 'Intermediate',
          sessions: 30, fee:'5,000,000',
          desc: lang==='vi' ? 'Nhắm mục tiêu IELTS 6.0–7.0. Luyện đề chuyên sâu.' : 'Target IELTS 6.0–7.0. Intensive mock tests.' },
        { icon:'bi-emoji-smile-fill', color:'#f59e0b', bg:'#fffbeb',
          name: lang==='vi' ? 'Kids English A1' : 'Kids English A1',
          level: lang==='vi' ? 'Thiếu nhi 6–12 tuổi' : 'Kids 6–12 yrs',
          sessions: 20, fee:'2,500,000',
          desc: lang==='vi' ? 'Tiếng Anh vui - học qua trò chơi và hoạt động.' : 'Fun English through games and activities.' },
        { icon:'bi-briefcase-fill', color:'#0891b2', bg:'#ecfeff',
          name: lang==='vi' ? 'Giao tiếp người đi làm' : 'Workplace English',
          level: lang==='vi' ? 'Mọi trình độ' : 'All levels',
          sessions: 20, fee:'3,000,000',
          desc: lang==='vi' ? 'Tiếng Anh thực chiến cho công việc hàng ngày.' : 'Practical English for everyday work situations.' },
      ] %>

      <% courses.forEach(c => { %>
      <div class="lp-course-card">
        <div class="lp-course-icon" style="background:<%= c.bg %>; color:<%= c.color %>">
          <i class="bi <%= c.icon %>"></i>
        </div>
        <div class="lp-course-body">
          <div class="lp-course-level"><%= c.level %></div>
          <h3 class="lp-course-name"><%= c.name %></h3>
          <p class="lp-course-desc"><%= c.desc %></p>
        </div>
        <div class="lp-course-footer">
          <div>
            <span class="lp-course-meta"><i class="bi bi-calendar3 me-1"></i><%= c.sessions %> <%= lang==='vi' ? 'buổi' : 'sessions' %></span>
          </div>
          <div class="lp-course-fee"><%= c.fee %> ₫</div>
        </div>
      </div>
      <% }) %>
    </div>

    <div class="text-center mt-5">
      <a href="#contact" class="lp-btn-primary lp-btn-lg">
        <%= lang==='vi' ? 'Tư vấn chọn khóa phù hợp' : 'Get personalised advice' %>
        <i class="bi bi-arrow-right ms-2"></i>
      </a>
    </div>
  </div>
</section>

<!-- ── WHY US ──────────────────────────────────────────────── -->
<section class="lp-section lp-section-cloud" id="why">
  <div class="container">
    <div class="lp-section-header">
      <p class="lp-section-eyebrow"><%= lang==='vi' ? 'Điểm khác biệt' : 'What sets us apart' %></p>
      <h2 class="lp-section-title">
        <%= lang==='vi' ? 'Tại sao chọn ABest?' : 'Why choose ABest?' %>
      </h2>
    </div>

    <div class="lp-features-grid">
      <% const features = [
        { icon:'bi-person-check-fill', color:'#ff385c',
          title: lang==='vi' ? 'Giáo viên chất lượng cao' : 'High-quality teachers',
          desc:  lang==='vi' ? 'Đội ngũ giáo viên có chứng chỉ quốc tế IELTS 8.0+, CELTA, có kinh nghiệm giảng dạy thực tế.' : 'Certified teachers with IELTS 8.0+, CELTA, real-world teaching experience.' },
        { icon:'bi-map-fill', color:'#2563eb',
          title: lang==='vi' ? 'Lộ trình cá nhân hoá' : 'Personalised roadmap',
          desc:  lang==='vi' ? 'Kiểm tra đầu vào miễn phí, xây dựng lộ trình riêng theo mục tiêu và thời gian của bạn.' : 'Free placement test, custom roadmap built around your goal and schedule.' },
        { icon:'bi-shield-check-fill', color:'#059669',
          title: lang==='vi' ? 'Cam kết đầu ra' : 'Output guarantee',
          desc:  lang==='vi' ? 'Học lại miễn phí nếu không đạt mục tiêu đã cam kết sau khoá học.' : 'Free repeat course if you don\'t meet your committed target.' },
        { icon:'bi-calendar2-check-fill', color:'#7c3aed',
          title: lang==='vi' ? 'Lịch học linh hoạt' : 'Flexible schedule',
          desc:  lang==='vi' ? 'Nhiều ca học trong tuần, phù hợp với người đi làm, sinh viên và thiếu nhi.' : 'Multiple weekly slots for working adults, students, and children.' },
        { icon:'bi-people-fill', color:'#f59e0b',
          title: lang==='vi' ? 'Lớp nhỏ, sát sao' : 'Small classes',
          desc:  lang==='vi' ? 'Tối đa 15–20 học viên/lớp. Giáo viên chú ý và hỗ trợ từng cá nhân.' : 'Max 15–20 students per class. Individual attention guaranteed.' },
        { icon:'bi-chat-dots-fill', color:'#0891b2',
          title: lang==='vi' ? 'CSKH tận tâm' : 'Dedicated support',
          desc:  lang==='vi' ? 'Đội ngũ tư vấn và CSKH sẵn sàng hỗ trợ trước, trong và sau khoá học.' : 'Dedicated support team available before, during, and after your course.' },
      ] %>
      <% features.forEach(f => { %>
      <div class="lp-feature-card">
        <div class="lp-feature-icon" style="color:<%= f.color %>">
          <i class="bi <%= f.icon %>"></i>
        </div>
        <h4 class="lp-feature-title"><%= f.title %></h4>
        <p class="lp-feature-desc"><%= f.desc %></p>
      </div>
      <% }) %>
    </div>
  </div>
</section>

<!-- ── TEACHERS ────────────────────────────────────────────── -->
<section class="lp-section" id="teachers">
  <div class="container">
    <div class="lp-section-header">
      <p class="lp-section-eyebrow"><%= lang==='vi' ? 'Đội ngũ' : 'Our Team' %></p>
      <h2 class="lp-section-title">
        <%= lang==='vi' ? 'Giáo viên ABest' : 'ABest Teachers' %>
      </h2>
      <p class="lp-section-sub">
        <%= lang==='vi'
          ? 'Được tuyển chọn kỹ lưỡng — chứng chỉ quốc tế, kinh nghiệm dạy thực chiến, đam mê giảng dạy.'
          : 'Carefully selected — internationally certified, real teaching experience, passionate educators.' %>
      </p>
    </div>

    <div class="lp-teachers-grid">
      <% const teachers = [
        { name:'Ms. Linh Phạm', role:'IELTS / TOEIC', cert:'IELTS 8.5 · CELTA', avatar:'LP', color:'#ff385c' },
        { name:'Mr. Minh Trần', role:'Business English', cert:'IELTS 8.0 · MBA', avatar:'MT', color:'#2563eb' },
        { name:'Ms. Hoa Nguyễn', role:'Kids English', cert:'TESOL · 10 yr exp.', avatar:'HN', color:'#059669' },
        { name:'Mr. Tuấn Lê',   role:'IELTS Advanced', cert:'IELTS 9.0 · Oxford', avatar:'TL', color:'#7c3aed' },
      ] %>
      <% teachers.forEach(tc => { %>
      <div class="lp-teacher-card">
        <div class="lp-teacher-avatar" style="background:<%= tc.color %>">
          <%= tc.avatar %>
        </div>
        <div class="lp-teacher-info">
          <div class="lp-teacher-name"><%= tc.name %></div>
          <div class="lp-teacher-role"><%= tc.role %></div>
          <div class="lp-teacher-cert"><i class="bi bi-patch-check-fill me-1" style="color:var(--gold)"></i><%= tc.cert %></div>
        </div>
      </div>
      <% }) %>
    </div>
  </div>
</section>

<!-- ── TESTIMONIALS ────────────────────────────────────────── -->
<section class="lp-section lp-section-cloud">
  <div class="container">
    <div class="lp-section-header">
      <div class="lp-award-lockup">
        <div class="lp-laurel">❧</div>
        <div>
          <div class="lp-award-rating">4.9</div>
          <div class="lp-award-label"><%= lang==='vi' ? 'HỌC VIÊN YÊU THÍCH' : 'STUDENT FAVORITE' %></div>
          <div class="lp-award-sub"><%= lang==='vi' ? 'Dựa trên 800+ đánh giá' : 'Based on 800+ reviews' %></div>
        </div>
        <div class="lp-laurel lp-laurel-right">❧</div>
      </div>
    </div>

    <div class="lp-reviews-grid">
      <% const reviews = [
        { name:'Nguyễn Thu Hà', course:'TOEIC Foundation', score:'640 điểm', stars:5,
          text: lang==='vi' ? 'Trước khi học ABest mình chưa có nền tảng gì. Sau 3 tháng đạt 640 TOEIC, vượt kỳ vọng hoàn toàn!' : 'I had no foundation before ABest. After 3 months I scored 640 TOEIC — far beyond my expectations!' },
        { name:'Trần Văn Bảo', course:'IELTS Intermediate', score:'IELTS 6.5', stars:5,
          text: lang==='vi' ? 'Giáo viên tâm huyết, phương pháp dạy rất thực tế. Đạt 6.5 sau 6 tháng luyện tập cùng ABest.' : 'Dedicated teachers, very practical approach. Got 6.5 after 6 months with ABest.' },
        { name:'Lê Minh Châu', course:'Kids English', score:'', stars:5,
          text: lang==='vi' ? 'Con tôi 8 tuổi, tự tin nói tiếng Anh sau 4 tháng. Lớp nhỏ, cô giáo rất kiên nhẫn với trẻ em.' : 'My 8-year-old speaks confidently after 4 months. Small class, very patient teachers with kids.' },
      ] %>
      <% reviews.forEach(r => { %>
      <div class="lp-review-card">
        <div class="lp-review-stars">
          <% for(let i=0;i<5;i++) { %><i class="bi bi-star-fill" style="color:#fbbf24;font-size:14px"></i><% } %>
        </div>
        <p class="lp-review-text">"<%= r.text %>"</p>
        <div class="lp-review-footer">
          <div class="lp-review-avatar"><%= r.name.charAt(0) %></div>
          <div>
            <div class="lp-review-name"><%= r.name %></div>
            <div class="lp-review-meta"><%= r.course %><% if(r.score){ %> · <strong style="color:var(--gold)"><%= r.score %></strong><% } %></div>
          </div>
        </div>
      </div>
      <% }) %>
    </div>
  </div>
</section>

<!-- ── CONTACT / CTA ──────────────────────────────────────── -->
<section class="lp-section lp-cta-section" id="contact">
  <div class="container">
    <div class="lp-cta-card">
      <div class="lp-cta-content">
        <p class="lp-section-eyebrow" style="color:var(--gold-light)">
          <%= lang==='vi' ? 'Bắt đầu ngay hôm nay' : 'Start today' %>
        </p>
        <h2 class="lp-cta-title">
          <%= lang==='vi' ? 'Kiểm tra đầu vào miễn phí — 15 phút' : 'Free placement test — 15 minutes' %>
        </h2>
        <p class="lp-cta-sub">
          <%= lang==='vi'
            ? 'Để chúng tôi xác định đúng trình độ và tư vấn lộ trình phù hợp nhất cho bạn.'
            : 'Let us identify your level and build the most suitable learning roadmap for you.' %>
        </p>

        <form class="lp-contact-form" onsubmit="handleContact(event)">
          <div class="lp-form-row">
            <input type="text" class="lp-input" placeholder="<%= lang==='vi' ? 'Họ và tên' : 'Full name' %>" required>
            <input type="tel"  class="lp-input" placeholder="<%= lang==='vi' ? 'Số điện thoại' : 'Phone number' %>" required>
          </div>
          <div class="lp-form-row">
            <select class="lp-input lp-select">
              <option value=""><%= lang==='vi' ? 'Khóa học quan tâm' : 'Course of interest' %></option>
              <option>TOEIC Foundation</option>
              <option>TOEIC Advanced</option>
              <option>IELTS Pre</option>
              <option>IELTS Intermediate</option>
              <option><%= lang==='vi' ? 'Kids English A1' : 'Kids English A1' %></option>
              <option><%= lang==='vi' ? 'Giao tiếp người đi làm' : 'Workplace English' %></option>
            </select>
            <button type="submit" class="lp-btn-white lp-btn-lg">
              <%= lang==='vi' ? 'Đăng ký tư vấn' : 'Book consultation' %>
              <i class="bi bi-arrow-right ms-2"></i>
            </button>
          </div>
        </form>
      </div>
    </div>

    <!-- Info strip -->
    <div class="lp-info-strip">
      <div class="lp-info-item">
        <i class="bi bi-geo-alt-fill" style="color:var(--gold)"></i>
        <span>123 Nguyễn Văn A, Q.1, TP.HCM</span>
      </div>
      <div class="lp-info-item">
        <i class="bi bi-telephone-fill" style="color:var(--gold)"></i>
        <span>028-1234-5678</span>
      </div>
      <div class="lp-info-item">
        <i class="bi bi-clock-fill" style="color:var(--gold)"></i>
        <span><%= lang==='vi' ? 'T2–T7: 08:00–21:00' : 'Mon–Sat: 08:00–21:00' %></span>
      </div>
      <div class="lp-info-item">
        <i class="bi bi-envelope-fill" style="color:var(--gold)"></i>
        <span>hello@abest.edu.vn</span>
      </div>
    </div>
  </div>
</section>

<!-- ── FOOTER ─────────────────────────────────────────────── -->
<footer class="lp-footer">
  <div class="container">
    <div class="lp-footer-grid">
      <div class="lp-footer-brand">
        <a href="/" class="lp-logo">
          <img class="lp-logo-icon" src="/images/logo.svg" width="48" height="48" alt="ABest logo">
          <span class="lp-logo-text"> A.Best
          <span class="lp-logo-tagline">Excellence in Language</span>
          </span>
