<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h4 class="mb-0 fw-bold"><%= t('dashboard.title') %></h4>
    <small class="text-muted"><%= t('dashboard.welcome') %>, <%= user.fullName %></small>
  </div>
</div>

<!-- Stats Cards -->
<div class="row g-3 mb-4">
  <div class="col-sm-6 col-xl-3">
    <div class="card border-0 shadow-sm h-100">
      <div class="card-body d-flex align-items-center gap-3">
        <div class="rounded-circle bg-primary bg-opacity-10 p-3">
          <i class="bi bi-people-fill fs-4 text-primary"></i>
        </div>
        <div>
          <div class="fs-4 fw-bold"><%= stats.students %></div>
          <div class="text-muted small"><%= t('dashboard.total_students') %></div>
        </div>
      </div>
    </div>
  </div>
  <div class="col-sm-6 col-xl-3">
    <div class="card border-0 shadow-sm h-100">
      <div class="card-body d-flex align-items-center gap-3">
        <div class="rounded-circle bg-success bg-opacity-10 p-3">
          <i class="bi bi-journal-text fs-4 text-success"></i>
        </div>
        <div>
          <div class="fs-4 fw-bold"><%= stats.classes %></div>
          <div class="text-muted small"><%= t('dashboard.total_classes') %></div>
        </div>
      </div>
    </div>
  </div>
  <div class="col-sm-6 col-xl-3">
    <div class="card border-0 shadow-sm h-100">
      <div class="card-body d-flex align-items-center gap-3">
        <div class="rounded-circle bg-warning bg-opacity-10 p-3">
          <i class="bi bi-person-badge-fill fs-4 text-warning"></i>
        </div>
        <div>
          <div class="fs-4 fw-bold"><%= stats.teachers %></div>
          <div class="text-muted small"><%= t('dashboard.total_teachers') %></div>
        </div>
      </div>
    </div>
  </div>
  <div class="col-sm-6 col-xl-3">
    <div class="card border-0 shadow-sm h-100">
      <div class="card-body d-flex align-items-center gap-3">
        <div class="rounded-circle bg-info bg-opacity-10 p-3">
          <i class="bi bi-cash-coin fs-4 text-info"></i>
        </div>
        <div>
          <div class="fs-4 fw-bold">—</div>
          <div class="text-muted small"><%= t('dashboard.revenue_month') %></div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Quick Links -->
<div class="row g-3">
  <div class="col-md-6">
    <div class="card border-0 shadow-sm">
      <div class="card-header bg-white border-0 fw-semibold">
        <i class="bi bi-lightning-charge text-primary me-2"></i>Quick Actions
      </div>
      <div class="card-body">
        <div class="d-flex flex-wrap gap-2">
          <a href="/students/new" class="btn btn-outline-primary btn-sm">
            <i class="bi bi-person-plus me-1"></i><%= t('students.add') %>
          </a>
          <a href="/classes/new" class="btn btn-outline-success btn-sm">
            <i class="bi bi-plus-circle me-1"></i><%= t('classes.add') %>
          </a>
          <a href="/schedule" class="btn btn-outline-info btn-sm">
            <i class="bi bi-calendar3 me-1"></i><%= t('nav.schedule') %>
          </a>
        </div>
      </div>
    </div>
  </div>
  <div class="col-md-6">
    <div class="card border-0 shadow-sm">
      <div class="card-header bg-white border-0 fw-semibold">
        <i class="bi bi-info-circle text-muted me-2"></i>System Info
      </div>
      <div class="card-body">
        <table class="table table-sm table-borderless mb-0 small">
          <tr><td class="text-muted">Database</td><td class="fw-semibold">MySQL</td></tr>
          <tr><td class="text-muted">Version</td><td class="fw-semibold">1.0.0</td></tr>
          <tr><td class="text-muted">User</td><td class="fw-semibold"><%= user.role %></td></tr>
        </table>
      </div>
    </div>
  </div>
</div>
