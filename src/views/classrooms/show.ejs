<!-- Breadcrumb -->
<nav class="mb-4" style="font-size:13px;color:var(--ash)">
  <a href="/classrooms" style="color:var(--ash);text-decoration:none">
    <i class="bi bi-door-open me-1"></i><%= t('classrooms.title') %>
  </a>
  <span class="mx-2">/</span>
  <span style="color:var(--ink)"><%= classroom.room_name %></span>
</nav>

<div class="d-flex justify-content-between align-items-start mb-4 flex-wrap gap-3">
  <div class="d-flex align-items-center gap-3">
    <div style="
      width:56px;height:56px;border-radius:12px;background:var(--rausch);
      display:flex;align-items:center;justify-content:center;
      font-size:22px;color:#fff;flex-shrink:0">
      <i class="bi bi-door-open"></i>
    </div>
    <div>
      <h5 class="mb-0 fw-bold" style="font-size:18px"><%= classroom.room_name %></h5>
      <div style="font-size:13px;color:var(--ash)">
        <code><%= classroom.room_code %></code>
        &nbsp;·&nbsp;
        <% const b = classroom.status==='active'
          ? { cls:'badge-active',   lbl: lang==='vi' ? 'Đang dùng' : 'Active' }
          : { cls:'badge-inactive', lbl: lang==='vi' ? 'Ngừng'     : 'Inactive' }; %>
        <span class="badge <%= b.cls %>" style="padding:3px 10px"><%= b.lbl %></span>
      </div>
    </div>
  </div>

  <div class="d-flex gap-2">
    <a href="/classrooms/<%= classroom.id %>/edit" class="btn btn-primary">
      <i class="bi bi-pencil me-2"></i><%= t('common.edit') %>
    </a>
    <a href="/classrooms" class="btn btn-outline-secondary">
      <i class="bi bi-arrow-left me-1"></i><%= t('common.back') %>
    </a>
  </div>
</div>

<div class="row g-4">

  <!-- LEFT -->
  <div class="col-lg-8">
    <div class="card mb-4">
      <div class="card-header">
        <i class="bi bi-door-open me-2" style="color:var(--rausch)"></i>
        <%= lang==='vi' ? 'Thông tin phòng học' : 'Classroom information' %>
      </div>
      <div class="card-body p-0">
        <%
        const typeLabel = {
          classroom:    lang==='vi' ? 'Phòng học' : 'Classroom',
          lab:          lang==='vi' ? 'Phòng lab' : 'Lab',
          meeting_room: lang==='vi' ? 'Phòng họp' : 'Meeting Room',
        }[classroom.room_type] || classroom.room_type;
        const infoRows = [
          [t('classrooms.code'),     classroom.room_code],
          [t('classrooms.name'),     classroom.room_name],
          [t('classrooms.branch'),   classroom.branch_name || '—'],
          [t('classrooms.type'),     typeLabel],
          [t('classrooms.capacity'), classroom.capacity + (lang==='vi' ? ' chỗ' : ' seats')],
        ];
        %>
        <table class="table table-borderless mb-0">
          <% infoRows.forEach(([label, value]) => { %>
          <tr style="border-bottom:1px solid var(--hairline)">
            <td style="width:200px;padding:12px 20px;font-size:13px;color:var(--ash);font-weight:500">
              <%= label %>
            </td>
            <td style="padding:12px 20px;font-size:14px;color:var(--ink)">
              <%= value %>
            </td>
          </tr>
          <% }) %>
        </table>
      </div>
    </div>

    <% if (classroom.note) { %>
    <div class="card mb-4">
      <div class="card-header">
        <i class="bi bi-journal me-2" style="color:var(--rausch)"></i>
        <%= t('common.note') %>
      </div>
      <div class="card-body">
        <p class="mb-0" style="font-size:14px;color:var(--ink);white-space:pre-line;line-height:1.6">
          <%= classroom.note %>
        </p>
      </div>
    </div>
    <% } %>
  </div>

  <!-- RIGHT -->
  <div class="col-lg-4">
    <div class="card">
      <div class="card-header">
        <i class="bi bi-clock-history me-2" style="color:var(--rausch)"></i>
        <%= lang==='vi' ? 'Hệ thống' : 'System' %>
      </div>
      <div class="card-body p-0">
        <table class="table table-borderless mb-0">
          <tr>
            <td style="padding:12px 16px;font-size:12px;color:var(--ash)">
              <%= lang==='vi' ? 'Mã phòng' : 'Room code' %>
            </td>
            <td style="padding:12px 16px">
              <code style="font-size:13px"><%= classroom.room_code %></code>
            </td>
          </tr>
        </table>
      </div>
    </div>

    <div class="card mt-3">
      <div class="card-body d-flex flex-column gap-2">
        <a href="/classrooms/<%= classroom.id %>/edit" class="btn btn-primary w-100">
          <i class="bi bi-pencil me-2"></i><%= t('common.edit') %>
        </a>
        <% if (classroom.status !== 'inactive') { %>
          <form method="POST" action="/classrooms/<%= classroom.id %>/delete"
                onsubmit="return confirm('<%= lang==='vi' ? 'Ngừng phòng học này?' : 'Deactivate this classroom?' %>')">
            <button type="submit" class="btn btn-outline-danger w-100 btn-sm">
              <i class="bi bi-slash-circle me-2"></i>
              <%= lang==='vi' ? 'Ngừng phòng học' : 'Deactivate' %>
            </button>
          </form>
        <% } %>
      </div>
    </div>
  </div>

</div>
