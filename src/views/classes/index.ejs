<%
const STATUS_MAP = {
  planned:         { cls: 'badge-planned',   lbl: lang==='vi' ? 'Dự kiến'      : 'Planned' },
  open_enrollment: { cls: 'badge-active',    lbl: lang==='vi' ? 'Mở ghi danh'  : 'Enrolling' },
  ongoing:         { cls: 'badge-ongoing',   lbl: lang==='vi' ? 'Đang học'     : 'Ongoing' },
  completed:       { cls: 'badge-completed', lbl: lang==='vi' ? 'Đã kết thúc'  : 'Completed' },
  cancelled:       { cls: 'badge-cancelled', lbl: lang==='vi' ? 'Đã hủy'       : 'Cancelled' },
  postponed:       { cls: 'badge-inactive',  lbl: lang==='vi' ? 'Tạm hoãn'     : 'Postponed' },
};
%>

<!-- Page header -->
<div class="d-flex justify-content-between align-items-start mb-4">
  <div class="page-header mb-0">
    <div class="page-title"><%= t('classes.title') %></div>
    <div class="page-sub"><%= total %> <%= lang==='vi' ? 'lớp học' : 'classes' %></div>
  </div>
  <a href="/classes/new" class="btn btn-primary">
    <i class="bi bi-plus-circle me-2"></i><%= t('classes.add') %>
  </a>
</div>

<!-- Search + Filter bar -->
<form method="GET" action="/classes" class="mb-4">
  <div class="d-flex gap-2 flex-wrap">
    <div class="input-group" style="max-width:300px">
      <span class="input-group-text bg-white border-end-0" style="border-color:var(--hairline)">
        <i class="bi bi-search text-muted"></i>
      </span>
      <input type="text" name="search" class="form-control border-start-0 ps-0"
             style="border-color:var(--hairline)"
             placeholder="<%= lang==='vi' ? 'Tìm mã, tên lớp...' : 'Search code, name...' %>"
             value="<%= search %>">
    </div>

    <select name="status" class="form-select" style="width:auto;min-width:170px" onchange="this.form.submit()">
      <option value=""><%= lang==='vi' ? 'Tất cả trạng thái' : 'All status' %></option>
      <% Object.entries(STATUS_MAP).forEach(([val, info]) => { %>
        <option value="<%= val %>" <%= filterStatus===val ? 'selected' : '' %>><%= info.lbl %></option>
      <% }) %>
    </select>

    <select name="course_id" class="form-select" style="width:auto;min-width:180px" onchange="this.form.submit()">
      <option value=""><%= lang==='vi' ? 'Tất cả khóa học' : 'All courses' %></option>
      <% courses.forEach(co => { %>
        <option value="<%= co.id %>" <%= filterCourseId===String(co.id) ? 'selected' : '' %>>
          <%= co.course_name %>
        </option>
      <% }) %>
    </select>

    <% if (search || filterStatus || filterCourseId) { %>
      <a href="/classes" class="btn btn-outline-secondary">
        <i class="bi bi-x me-1"></i><%= lang==='vi' ? 'Xóa bộ lọc' : 'Clear' %>
      </a>
    <% } %>
    <button type="submit" class="btn btn-primary"><%= lang==='vi' ? 'Tìm' : 'Search' %></button>
  </div>
</form>

<!-- Table -->
<div class="card p-0">
  <% if (rows.length === 0) { %>
    <div class="text-center py-5">
      <i class="bi bi-journal-text" style="font-size:40px;color:var(--stone)"></i>
      <p class="mt-3 text-muted"><%= t('common.no_data') %></p>
      <a href="/classes/new" class="btn btn-primary btn-sm mt-1">
        <i class="bi bi-plus-circle me-1"></i><%= t('classes.add') %>
      </a>
    </div>
  <% } else { %>
  <div class="table-responsive">
    <table class="table mb-0">
      <thead>
        <tr>
          <th><%= t('classes.code') %></th>
          <th><%= t('classes.name') %></th>
          <th><%= t('classes.course') %></th>
          <th><%= lang==='vi' ? 'Giáo viên' : 'Teacher' %></th>
          <th><%= t('classes.start_date') %></th>
          <th><%= t('classes.end_date') %></th>
          <th><%= lang==='vi' ? 'Buổi' : 'Sessions' %></th>
          <th><%= t('common.status') %></th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% rows.forEach(c => {
          const b = STATUS_MAP[c.status] || { cls:'badge-inactive', lbl: c.status };
        %>
        <tr>
          <td><code style="font-size:12px;color:var(--ash)"><%= c.class_code %></code></td>
          <td>
            <a href="/classes/<%= c.id %>" class="fw-semibold text-decoration-none" style="color:var(--ink)">
              <%= c.class_name %>
            </a>
            <div style="font-size:11px;color:var(--ash)">
              <code><%= c.room_code %></code> · <%= c.timeslot_label %>
            </div>
          </td>
          <td style="color:var(--ash);font-size:13px"><%= c.course_name %></td>
          <td style="color:var(--ash);font-size:13px"><%= c.teacher_name || '—' %></td>
          <td style="color:var(--ash);font-size:13px">
            <%= c.start_date ? new Date(c.start_date).toLocaleDateString(lang==='vi' ? 'vi-VN' : 'en-GB') : '—' %>
          </td>
          <td style="color:var(--ash);font-size:13px">
            <%= c.expected_end_date ? new Date(c.expected_end_date).toLocaleDateString(lang==='vi' ? 'vi-VN' : 'en-GB') : '—' %>
          </td>
          <td style="font-size:13px">
            <span style="color:var(--ink);font-weight:500"><%= c.sessions_completed %></span>
            <span style="color:var(--ash)">/ <%= c.total_sessions %></span>
          </td>
          <td>
            <span class="badge <%= b.cls %>" style="padding:4px 10px"><%= b.lbl %></span>
          </td>
          <td class="text-end">
            <div class="d-flex justify-content-end gap-1">
              <a href="/classes/<%= c.id %>" class="btn btn-sm btn-outline-secondary"
                 title="<%= lang==='vi' ? 'Xem' : 'View' %>">
                <i class="bi bi-eye"></i>
              </a>
              <a href="/classes/<%= c.id %>/edit" class="btn btn-sm btn-outline-secondary"
                 title="<%= t('common.edit') %>">
                <i class="bi bi-pencil"></i>
              </a>
            </div>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
  <% } %>
</div>

<!-- Pagination -->
<% if (totalPages > 1) { %>
<nav class="d-flex justify-content-between align-items-center mt-4">
  <span class="small text-muted">
    <%= lang==='vi' ? `Trang ${page} / ${totalPages} — ${total} lớp` : `Page ${page} of ${totalPages} — ${total} classes` %>
  </span>
  <ul class="pagination pagination-sm mb-0">
    <li class="page-item <%= page<=1 ? 'disabled' : '' %>">
      <a class="page-link" href="?page=<%= page-1 %>&search=<%= search %>&status=<%= filterStatus %>&course_id=<%= filterCourseId %>">
        <i class="bi bi-chevron-left"></i>
      </a>
    </li>
    <% for(let p=Math.max(1,page-2); p<=Math.min(totalPages,page+2); p++) { %>
      <li class="page-item <%= p===page ? 'active' : '' %>">
        <a class="page-link" href="?page=<%= p %>&search=<%= search %>&status=<%= filterStatus %>&course_id=<%= filterCourseId %>"><%= p %></a>
      </li>
    <% } %>
    <li class="page-item <%= page>=totalPages ? 'disabled' : '' %>">
      <a class="page-link" href="?page=<%= page+1 %>&search=<%= search %>&status=<%= filterStatus %>&course_id=<%= filterCourseId %>">
        <i class="bi bi-chevron-right"></i>
      </a>
    </li>
  </ul>
</nav>
<% } %>

<style>
.page-link { border-color: var(--hairline); color: var(--ink); font-size:13px }
.page-item.active .page-link { background: var(--rausch); border-color: var(--rausch); }
</style>
