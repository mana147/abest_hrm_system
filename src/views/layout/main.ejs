<!DOCTYPE html>
<html lang="<%= lang %>">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' ? title + ' — HRM' : 'HRM System' %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
  <link href="/css/custom.css" rel="stylesheet">
</head>
<body>
<div id="wrapper">

  <!-- ── SIDEBAR ─────────────────────────────────────── -->
  <nav id="sidebar">
    <!-- Brand -->
    <div class="sidebar-brand d-flex align-items-center gap-2">
      <div class="sidebar-brand-icon">
        <i class="bi bi-building-fill text-white" style="font-size:15px"></i>
      </div>
      <span class="sidebar-brand-text fw-bold text-white" style="font-size:15px">HRM System</span>
    </div>

    <!-- Nav -->
    <ul class="nav flex-column pt-1 pb-2 flex-grow-1" style="overflow-y:auto">
      <li class="nav-item">
        <a class="nav-link <%= page==='dashboard' ? 'active' : '' %>" href="/dashboard">
          <i class="bi bi-speedometer2"></i>
          <span class="sidebar-label"><%= t('nav.dashboard') %></span>
        </a>
      </li>

      <div class="sidebar-section-label sidebar-label"><%= lang==='vi' ? 'Nhân sự' : 'People' %></div>
      <li class="nav-item">
        <a class="nav-link <%= page==='students' ? 'active' : '' %>" href="/students">
          <i class="bi bi-people"></i>
          <span class="sidebar-label"><%= t('nav.students') %></span>
        </a>
      </li>
      <li class="nav-item">
        <a class="nav-link <%= page==='teachers' ? 'active' : '' %>" href="/teachers">
          <i class="bi bi-person-badge"></i>
          <span class="sidebar-label"><%= t('nav.teachers') %></span>
        </a>
      </li>
      <li class="nav-item">
        <a class="nav-link <%= page==='staff' ? 'active' : '' %>" href="/staff">
          <i class="bi bi-person-workspace"></i>
          <span class="sidebar-label"><%= t('nav.staff') %></span>
        </a>
      </li>

      <div class="sidebar-section-label sidebar-label"><%= lang==='vi' ? 'Học thuật' : 'Academic' %></div>
      <li class="nav-item">
        <a class="nav-link <%= page==='classes' ? 'active' : '' %>" href="/classes">
          <i class="bi bi-journal-text"></i>
          <span class="sidebar-label"><%= t('nav.classes') %></span>
        </a>
      </li>
      <li class="nav-item">
        <a class="nav-link <%= page==='schedule' ? 'active' : '' %>" href="/schedule">
          <i class="bi bi-calendar3"></i>
          <span class="sidebar-label"><%= t('nav.schedule') %></span>
        </a>
      </li>

      <div class="sidebar-section-label sidebar-label"><%= lang==='vi' ? 'Tài chính' : 'Finance' %></div>
      <li class="nav-item">
        <a class="nav-link <%= page==='finance' ? 'active' : '' %>" href="/finance">
          <i class="bi bi-cash-coin"></i>
          <span class="sidebar-label"><%= t('nav.finance') %></span>
        </a>
      </li>
    </ul>

    <!-- User info -->
    <div class="sidebar-footer">
      <div class="d-flex align-items-center gap-2">
        <div style="width:32px;height:32px;border-radius:50%;background:var(--rausch);display:flex;align-items:center;justify-content:center;flex-shrink:0">
          <span class="text-white fw-bold" style="font-size:13px">
            <%= user ? user.fullName.charAt(0).toUpperCase() : 'U' %>
          </span>
        </div>
        <div class="sidebar-label" style="min-width:0">
          <div class="text-white fw-semibold text-truncate" style="font-size:13px"><%= user ? user.fullName : '' %></div>
          <div style="font-size:11px;color:rgba(255,255,255,0.45)"><%= user ? user.role : '' %></div>
        </div>
      </div>
    </div>
  </nav>

  <!-- ── MAIN CONTENT ────────────────────────────────── -->
  <div id="content">

    <!-- Topbar -->
    <nav class="topbar">
      <button class="topbar-toggle" id="sidebarToggle">
        <i class="bi bi-list" style="font-size:18px"></i>
      </button>
      <span style="font-size:14px;color:var(--ash);font-weight:500">
        <%= typeof title !== 'undefined' ? title : '' %>
      </span>
      <div class="ms-auto d-flex align-items-center gap-2">
        <a href="/language/vi" class="lang-btn <%= lang==='vi' ? 'active' : '' %>">VI</a>
        <a href="/language/en" class="lang-btn <%= lang==='en' ? 'active' : '' %>">EN</a>
        <a href="/auth/logout" class="logout-btn" title="<%= t('nav.logout') %>">
          <i class="bi bi-box-arrow-right"></i>
        </a>
      </div>
    </nav>

    <!-- Flash -->
    <% if ((success && success.length > 0) || (error && error.length > 0)) { %>
    <div style="padding:12px 28px 0">
      <% if (success && success.length > 0) { %>
        <div class="alert alert-success alert-dismissible fade show py-2 mb-2">
          <i class="bi bi-check-circle me-2"></i><%= success[0] %>
          <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
      <% } %>
      <% if (error && error.length > 0) { %>
        <div class="alert alert-danger alert-dismissible fade show py-2 mb-2">
          <i class="bi bi-exclamation-circle me-2"></i><%= error[0] %>
          <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
      <% } %>
    </div>
    <% } %>

    <!-- Body -->
    <main><%- body %></main>

    <div class="app-footer">
      HRM System &copy; <%= new Date().getFullYear() %> &nbsp;·&nbsp; Training Center Management
    </div>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="/js/main.js"></script>
</body>
</html>
