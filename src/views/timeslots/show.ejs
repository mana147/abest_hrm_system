<%
const DAY_LABELS = { '0':'CN','1':'T2','2':'T3','3':'T4','4':'T5','5':'T6','6':'T7' };
const DAY_LABELS_EN = { '0':'Sun','1':'Mon','2':'Tue','3':'Wed','4':'Thu','5':'Fri','6':'Sat' };
function showWeekdays(pattern) {
  if (!pattern) return '—';
  const map = lang==='vi' ? DAY_LABELS : DAY_LABELS_EN;
  return pattern.split(',').map(d => map[d] || d).join(' – ');
}
%>

<!-- Breadcrumb -->
<nav class="mb-4" style="font-size:13px;color:var(--ash)">
  <a href="/timeslots" style="color:var(--ash);text-decoration:none">
    <i class="bi bi-clock me-1"></i><%= t('timeslots.title') %>
  </a>
  <span class="mx-2">/</span>
  <span style="color:var(--ink)"><%= timeslot.label %></span>
</nav>

<div class="d-flex justify-content-between align-items-start mb-4 flex-wrap gap-3">
  <div class="d-flex align-items-center gap-3">
    <div style="
      width:56px;height:56px;border-radius:12px;background:var(--rausch);
      display:flex;align-items:center;justify-content:center;
      font-size:22px;color:#fff;flex-shrink:0">
      <i class="bi bi-clock"></i>
    </div>
    <div>
      <h5 class="mb-0 fw-bold" style="font-size:18px"><%= timeslot.label %></h5>
      <div style="font-size:13px;color:var(--ash)">
        <code><%= timeslot.timeslot_code %></code>
        &nbsp;·&nbsp;
        <% const b = timeslot.status==='active'
          ? { cls:'badge-active',   lbl: lang==='vi' ? 'Đang dùng' : 'Active' }
          : { cls:'badge-inactive', lbl: lang==='vi' ? 'Ngừng'     : 'Inactive' }; %>
        <span class="badge <%= b.cls %>" style="padding:3px 10px"><%= b.lbl %></span>
      </div>
    </div>
  </div>

  <div class="d-flex gap-2">
    <a href="/timeslots/<%= timeslot.id %>/edit" class="btn btn-primary">
      <i class="bi bi-pencil me-2"></i><%= t('common.edit') %>
    </a>
    <a href="/timeslots" class="btn btn-outline-secondary">
      <i class="bi bi-arrow-left me-1"></i><%= t('common.back') %>
    </a>
  </div>
</div>

<div class="row g-4">

  <!-- LEFT -->
  <div class="col-lg-8">
    <div class="card mb-4">
      <div class="card-header">
        <i class="bi bi-clock me-2" style="color:var(--rausch)"></i>
        <%= lang==='vi' ? 'Thông tin khung giờ' : 'Timeslot information' %>
      </div>
      <div class="card-body p-0">
        <table class="table table-borderless mb-0">
          <% const infoRows = [
            [t('timeslots.code'),     timeslot.timeslot_code],
            [t('timeslots.label'),    timeslot.label],
            [t('timeslots.weekdays'), showWeekdays(timeslot.weekdays_pattern)],
            [t('timeslots.start'),    timeslot.start_time],
            [t('timeslots.end'),      timeslot.end_time],
            [t('timeslots.per_week'), timeslot.sessions_per_week + (lang==='vi' ? ' buổi/tuần' : ' sessions/week')],
          ]; %>
          <% infoRows.forEach(([label, value]) => { %>
          <tr style="border-bottom:1px solid var(--hairline)">
            <td style="width:200px;padding:12px 20px;font-size:13px;color:var(--ash);font-weight:500">
              <%= label %>
            </td>
            <td style="padding:12px 20px;font-size:14px;color:var(--ink);font-weight:500">
              <%= value %>
            </td>
          </tr>
          <% }) %>
        </table>
      </div>
    </div>
  </div>

  <!-- RIGHT -->
  <div class="col-lg-4">
    <div class="card">
      <div class="card-header">
        <i class="bi bi-clock-history me-2" style="color:var(--rausch)"></i>
        <%= lang==='vi' ? 'Hệ thống' : 'System' %>
      </div>
      <div class="card-body p-0">
        <table class="table table-borderless mb-0">
          <tr>
            <td style="padding:12px 16px;font-size:12px;color:var(--ash)">
              <%= lang==='vi' ? 'Mã khung giờ' : 'Timeslot code' %>
            </td>
            <td style="padding:12px 16px">
              <code style="font-size:13px"><%= timeslot.timeslot_code %></code>
            </td>
          </tr>
        </table>
      </div>
    </div>

    <div class="card mt-3">
      <div class="card-body d-flex flex-column gap-2">
        <a href="/timeslots/<%= timeslot.id %>/edit" class="btn btn-primary w-100">
          <i class="bi bi-pencil me-2"></i><%= t('common.edit') %>
        </a>
        <% if (timeslot.status !== 'inactive') { %>
          <form method="POST" action="/timeslots/<%= timeslot.id %>/delete"
                onsubmit="return confirm('<%= lang==='vi' ? 'Ngừng khung giờ này?' : 'Deactivate this timeslot?' %>')">
            <button type="submit" class="btn btn-outline-danger w-100 btn-sm">
              <i class="bi bi-slash-circle me-2"></i>
              <%= lang==='vi' ? 'Ngừng khung giờ' : 'Deactivate' %>
            </button>
          </form>
        <% } %>
      </div>
    </div>
  </div>

</div>
