<!-- Page header -->
<div class="d-flex justify-content-between align-items-start mb-4">
  <div class="page-header mb-0">
    <div class="page-title"><%= t('students.title') %></div>
    <div class="page-sub"><%= total %> <%= lang==='vi' ? 'học viên' : 'students' %></div>
  </div>
  <a href="/students/new" class="btn btn-primary">
    <i class="bi bi-person-plus me-2"></i><%= t('students.add') %>
  </a>
</div>

<!-- Search + Filter bar -->
<form method="GET" action="/students" class="mb-4">
  <div class="d-flex gap-2 flex-wrap">
    <div class="input-group" style="max-width:340px">
      <span class="input-group-text bg-white border-end-0" style="border-color:var(--hairline)">
        <i class="bi bi-search text-muted"></i>
      </span>
      <input type="text" name="search" class="form-control border-start-0 ps-0"
             style="border-color:var(--hairline)"
             placeholder="<%= lang==='vi' ? 'Tìm tên, SĐT, mã học viên...' : 'Search name, phone, code...' %>"
             value="<%= search %>">
    </div>

    <select name="status" class="form-select" style="width:auto;min-width:160px"
            onchange="this.form.submit()">
      <option value=""><%= lang==='vi' ? 'Tất cả trạng thái' : 'All status' %></option>
      <option value="active"    <%= filterStatus==='active'    ? 'selected' : '' %>>
        <%= lang==='vi' ? '✓ Đang học' : '✓ Active' %>
      </option>
      <option value="graduated" <%= filterStatus==='graduated' ? 'selected' : '' %>>
        <%= lang==='vi' ? '🎓 Đã tốt nghiệp' : '🎓 Graduated' %>
      </option>
      <option value="dropped"   <%= filterStatus==='dropped'   ? 'selected' : '' %>>
        <%= lang==='vi' ? '✗ Đã nghỉ' : '✗ Dropped' %>
      </option>
      <option value="inactive"  <%= filterStatus==='inactive'  ? 'selected' : '' %>>
        <%= lang==='vi' ? '— Ngừng' : '— Inactive' %>
      </option>
    </select>

    <% if (search || filterStatus) { %>
      <a href="/students" class="btn btn-outline-secondary">
        <i class="bi bi-x me-1"></i><%= lang==='vi' ? 'Xóa bộ lọc' : 'Clear' %>
      </a>
    <% } %>

    <button type="submit" class="btn btn-primary">
      <%= lang==='vi' ? 'Tìm' : 'Search' %>
    </button>
  </div>
</form>

<!-- Table -->
<div class="card p-0">
  <% if (rows.length === 0) { %>
    <div class="text-center py-5">
      <i class="bi bi-people" style="font-size:40px;color:var(--stone)"></i>
      <p class="mt-3 text-muted"><%= t('common.no_data') %></p>
      <a href="/students/new" class="btn btn-primary btn-sm mt-1">
        <i class="bi bi-person-plus me-1"></i><%= t('students.add') %>
      </a>
    </div>
  <% } else { %>
  <div class="table-responsive">
    <table class="table mb-0">
      <thead>
        <tr>
          <th><%= lang==='vi' ? 'Mã HV' : 'Code' %></th>
          <th><%= t('students.name') %></th>
          <th><%= t('students.phone') %></th>
          <th><%= t('students.level') %></th>
          <th><%= t('students.source') %></th>
          <th><%= t('common.status') %></th>
          <th><%= t('common.created_at') %></th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% rows.forEach(s => { %>
        <tr>
          <td>
            <code style="font-size:12px;color:var(--ash)"><%= s.student_code %></code>
          </td>
          <td>
            <a href="/students/<%= s.id %>" class="fw-semibold text-decoration-none" style="color:var(--ink)">
              <%= s.full_name %>
            </a>
          </td>
          <td style="color:var(--ash)"><%= s.phone || '—' %></td>
          <td style="color:var(--ash)"><%= s.level_current || '—' %></td>
          <td style="color:var(--ash)"><%= s.source || '—' %></td>
          <td>
            <% const badgeMap = {
              active:    { cls:'badge-active',    lbl: lang==='vi' ? 'Đang học' : 'Active' },
              graduated: { cls:'badge-completed', lbl: lang==='vi' ? 'Tốt nghiệp' : 'Graduated' },
              dropped:   { cls:'badge-cancelled', lbl: lang==='vi' ? 'Đã nghỉ' : 'Dropped' },
              inactive:  { cls:'badge-inactive',  lbl: lang==='vi' ? 'Ngừng' : 'Inactive' },
            };
            const b = badgeMap[s.status] || { cls:'badge-inactive', lbl: s.status }; %>
            <span class="badge <%= b.cls %>" style="padding:4px 10px"><%= b.lbl %></span>
          </td>
          <td style="color:var(--ash);font-size:13px">
            <%= new Date(s.created_at).toLocaleDateString(lang==='vi' ? 'vi-VN' : 'en-GB') %>
          </td>
          <td class="text-end">
            <div class="d-flex justify-content-end gap-1">
              <a href="/students/<%= s.id %>"
                 class="btn btn-sm btn-outline-secondary" title="<%= lang==='vi' ? 'Xem' : 'View' %>">
                <i class="bi bi-eye"></i>
              </a>
              <a href="/students/<%= s.id %>/edit"
                 class="btn btn-sm btn-outline-secondary" title="<%= t('common.edit') %>">
                <i class="bi bi-pencil"></i>
              </a>
            </div>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
  <% } %>
</div>

<!-- Pagination -->
<% if (totalPages > 1) { %>
<nav class="d-flex justify-content-between align-items-center mt-4">
  <span class="small text-muted">
    <%= lang==='vi'
      ? `Trang ${page} / ${totalPages} — ${total} học viên`
      : `Page ${page} of ${totalPages} — ${total} students` %>
  </span>
  <ul class="pagination pagination-sm mb-0">
    <li class="page-item <%= page<=1 ? 'disabled' : '' %>">
      <a class="page-link"
         href="?page=<%= page-1 %>&search=<%= search %>&status=<%= filterStatus %>">
        <i class="bi bi-chevron-left"></i>
      </a>
    </li>
    <% for(let p=Math.max(1,page-2); p<=Math.min(totalPages,page+2); p++) { %>
      <li class="page-item <%= p===page ? 'active' : '' %>">
        <a class="page-link"
           href="?page=<%= p %>&search=<%= search %>&status=<%= filterStatus %>">
          <%= p %>
        </a>
      </li>
    <% } %>
    <li class="page-item <%= page>=totalPages ? 'disabled' : '' %>">
      <a class="page-link"
         href="?page=<%= page+1 %>&search=<%= search %>&status=<%= filterStatus %>">
        <i class="bi bi-chevron-right"></i>
      </a>
    </li>
  </ul>
</nav>
<% } %>

<style>
.page-link { border-color: var(--hairline); color: var(--ink); font-size:13px }
.page-item.active .page-link { background: var(--rausch); border-color: var(--rausch); }
</style>
