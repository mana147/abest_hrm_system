<!-- Breadcrumb -->
<nav class="mb-4" style="font-size:13px;color:var(--ash)">
  <a href="/students" style="color:var(--ash);text-decoration:none">
    <i class="bi bi-people me-1"></i><%= t('students.title') %>
  </a>
  <span class="mx-2">/</span>
  <span style="color:var(--ink)"><%= student.full_name %></span>
</nav>

<div class="d-flex justify-content-between align-items-start mb-4 flex-wrap gap-3">
  <!-- Avatar + name -->
  <div class="d-flex align-items-center gap-3">
    <div style="
      width:56px;height:56px;border-radius:50%;background:var(--rausch);
      display:flex;align-items:center;justify-content:center;
      font-size:22px;font-weight:700;color:#fff;flex-shrink:0">
      <%= student.full_name.charAt(0).toUpperCase() %>
    </div>
    <div>
      <h5 class="mb-0 fw-bold" style="font-size:18px"><%= student.full_name %></h5>
      <div style="font-size:13px;color:var(--ash)">
        <code><%= student.student_code %></code>
        &nbsp;·&nbsp;
        <% const badgeMap = {
          active:    { cls:'badge-active',    lbl: lang==='vi' ? 'Đang học' : 'Active' },
          graduated: { cls:'badge-completed', lbl: lang==='vi' ? 'Tốt nghiệp' : 'Graduated' },
          dropped:   { cls:'badge-cancelled', lbl: lang==='vi' ? 'Đã nghỉ' : 'Dropped' },
          inactive:  { cls:'badge-inactive',  lbl: lang==='vi' ? 'Ngừng' : 'Inactive' },
        };
        const b = badgeMap[student.status] || { cls:'badge-inactive', lbl: student.status }; %>
        <span class="badge <%= b.cls %>" style="padding:3px 10px"><%= b.lbl %></span>
      </div>
    </div>
  </div>

  <!-- Actions -->
  <div class="d-flex gap-2">
    <a href="/students/<%= student.id %>/edit" class="btn btn-primary">
      <i class="bi bi-pencil me-2"></i><%= t('common.edit') %>
    </a>
    <a href="/students" class="btn btn-outline-secondary">
      <i class="bi bi-arrow-left me-1"></i><%= t('common.back') %>
    </a>
  </div>
</div>

<div class="row g-4">

  <!-- LEFT -->
  <div class="col-lg-8">

    <!-- Info card -->
    <div class="card mb-4">
      <div class="card-header">
        <i class="bi bi-person me-2" style="color:var(--rausch)"></i>
        <%= lang==='vi' ? 'Thông tin học viên' : 'Student information' %>
      </div>
      <div class="card-body p-0">
        <table class="table table-borderless mb-0">
          <% const rows = [
            [lang==='vi' ? 'Họ và tên'    : 'Full name',    student.full_name],
            [lang==='vi' ? 'Ngày sinh'    : 'Date of birth', student.date_of_birth
              ? new Date(student.date_of_birth).toLocaleDateString(lang==='vi' ? 'vi-VN' : 'en-GB')
              : '—'],
            [lang==='vi' ? 'Giới tính'    : 'Gender',       student.gender || '—'],
            [lang==='vi' ? 'Số điện thoại': 'Phone',        student.phone || '—'],
            ['Email',                                        student.email || '—'],
            [lang==='vi' ? 'Địa chỉ'      : 'Address',      student.address || '—'],
            [lang==='vi' ? 'Trình độ'     : 'Level',        student.level_current || '—'],
            [lang==='vi' ? 'Nguồn'        : 'Source',       student.source || '—'],
          ]; %>
          <% rows.forEach(([label, value]) => { %>
          <tr style="border-bottom:1px solid var(--hairline)">
            <td style="width:180px;padding:12px 20px;font-size:13px;color:var(--ash);font-weight:500">
              <%= label %>
            </td>
            <td style="padding:12px 20px;font-size:14px;color:var(--ink)">
              <%= value %>
            </td>
          </tr>
          <% }) %>
        </table>
      </div>
    </div>

    <!-- Parent card -->
    <% if (student.parent_name || student.parent_phone) { %>
    <div class="card mb-4">
      <div class="card-header">
        <i class="bi bi-people me-2" style="color:var(--rausch)"></i>
        <%= lang==='vi' ? 'Phụ huynh / Người liên hệ' : 'Parent / Guardian' %>
      </div>
      <div class="card-body p-0">
        <table class="table table-borderless mb-0">
          <tr style="border-bottom:1px solid var(--hairline)">
            <td style="width:180px;padding:12px 20px;font-size:13px;color:var(--ash);font-weight:500">
              <%= lang==='vi' ? 'Họ tên' : 'Name' %>
            </td>
            <td style="padding:12px 20px;font-size:14px;color:var(--ink)">
              <%= student.parent_name || '—' %>
            </td>
          </tr>
          <tr>
            <td style="width:180px;padding:12px 20px;font-size:13px;color:var(--ash);font-weight:500">
              <%= lang==='vi' ? 'Số điện thoại' : 'Phone' %>
            </td>
            <td style="padding:12px 20px;font-size:14px;color:var(--ink)">
              <%= student.parent_phone || '—' %>
            </td>
          </tr>
        </table>
      </div>
    </div>
    <% } %>

    <!-- Note -->
    <% if (student.note) { %>
    <div class="card mb-4">
      <div class="card-header">
        <i class="bi bi-journal me-2" style="color:var(--rausch)"></i>
        <%= t('common.note') %>
      </div>
      <div class="card-body">
        <p class="mb-0" style="font-size:14px;color:var(--ink);white-space:pre-line;line-height:1.6">
          <%= student.note %>
        </p>
      </div>
    </div>
    <% } %>

  </div>

  <!-- RIGHT -->
  <div class="col-lg-4">
    <div class="card">
      <div class="card-header">
        <i class="bi bi-clock-history me-2" style="color:var(--rausch)"></i>
        <%= lang==='vi' ? 'Hệ thống' : 'System' %>
      </div>
      <div class="card-body p-0">
        <table class="table table-borderless mb-0">
          <tr style="border-bottom:1px solid var(--hairline)">
            <td style="padding:12px 16px;font-size:12px;color:var(--ash)">
              <%= lang==='vi' ? 'Ngày tạo' : 'Created' %>
            </td>
            <td style="padding:12px 16px;font-size:13px;color:var(--ink)">
              <%= new Date(student.created_at).toLocaleString(lang==='vi' ? 'vi-VN' : 'en-GB') %>
            </td>
          </tr>
          <tr>
            <td style="padding:12px 16px;font-size:12px;color:var(--ash)">
              <%= lang==='vi' ? 'Mã học viên' : 'Student code' %>
            </td>
            <td style="padding:12px 16px">
              <code style="font-size:13px"><%= student.student_code %></code>
            </td>
          </tr>
        </table>
      </div>
    </div>

    <!-- Quick actions -->
    <div class="card mt-3">
      <div class="card-body d-flex flex-column gap-2">
        <a href="/students/<%= student.id %>/edit" class="btn btn-primary w-100">
          <i class="bi bi-pencil me-2"></i><%= t('common.edit') %>
        </a>
        <% if (student.status !== 'inactive') { %>
          <form method="POST" action="/students/<%= student.id %>/delete"
                onsubmit="return confirm('<%= lang==='vi' ? 'Ngừng hoạt động học viên này?' : 'Deactivate this student?' %>')">
            <button type="submit" class="btn btn-outline-danger w-100 btn-sm">
              <i class="bi bi-person-dash me-2"></i>
              <%= lang==='vi' ? 'Ngừng hoạt động' : 'Deactivate' %>
            </button>
          </form>
        <% } %>
      </div>
    </div>
  </div>

</div>
