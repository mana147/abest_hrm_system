<!-- Header -->
<div class="d-flex justify-content-between align-items-start mb-4">
  <div class="page-header mb-0">
    <div class="page-title"><%= t('teachers.title') %></div>
    <div class="page-sub"><%= total %> <%= lang==='vi' ? 'giáo viên' : 'teachers' %></div>
  </div>
  <a href="/teachers/new" class="btn btn-primary">
    <i class="bi bi-person-plus me-2"></i><%= t('teachers.add') %>
  </a>
</div>

<!-- Search + Filter -->
<form method="GET" action="/teachers" class="mb-4">
  <div class="d-flex gap-2 flex-wrap">
    <div class="input-group" style="max-width:320px">
      <span class="input-group-text bg-white border-end-0" style="border-color:var(--hairline)">
        <i class="bi bi-search text-muted"></i>
      </span>
      <input type="text" name="search" class="form-control border-start-0 ps-0"
             style="border-color:var(--hairline)"
             placeholder="<%= lang==='vi' ? 'Tên, SĐT, mã giáo viên...' : 'Name, phone, code...' %>"
             value="<%= search %>">
    </div>

    <select name="type" class="form-select" style="width:auto;min-width:160px"
            onchange="this.form.submit()">
      <option value=""><%= lang==='vi' ? 'Tất cả loại HĐ' : 'All contract types' %></option>
      <option value="fulltime"  <%= filterType==='fulltime'  ? 'selected':'' %>><%= lang==='vi' ? 'Cơ hữu'    : 'Full-time'  %></option>
      <option value="parttime"  <%= filterType==='parttime'  ? 'selected':'' %>><%= lang==='vi' ? 'Bán thời gian' : 'Part-time' %></option>
      <option value="freelance" <%= filterType==='freelance' ? 'selected':'' %>>Freelance</option>
    </select>

    <select name="status" class="form-select" style="width:auto;min-width:150px"
            onchange="this.form.submit()">
      <option value=""><%= lang==='vi' ? 'Tất cả trạng thái' : 'All status' %></option>
      <option value="active"   <%= filterStatus==='active'   ? 'selected':'' %>>✓ <%= lang==='vi' ? 'Đang dạy' : 'Active' %></option>
      <option value="inactive" <%= filterStatus==='inactive' ? 'selected':'' %>>— <%= lang==='vi' ? 'Ngừng'   : 'Inactive' %></option>
    </select>

    <% if (search || filterStatus || filterType) { %>
      <a href="/teachers" class="btn btn-outline-secondary">
        <i class="bi bi-x me-1"></i><%= lang==='vi' ? 'Xóa bộ lọc' : 'Clear' %>
      </a>
    <% } %>
    <button type="submit" class="btn btn-primary"><%= lang==='vi' ? 'Tìm' : 'Search' %></button>
  </div>
</form>

<!-- Table -->
<div class="card p-0">
  <% if (rows.length === 0) { %>
    <div class="text-center py-5">
      <i class="bi bi-person-badge" style="font-size:40px;color:var(--stone)"></i>
      <p class="mt-3 text-muted"><%= t('common.no_data') %></p>
      <a href="/teachers/new" class="btn btn-primary btn-sm mt-1">
        <i class="bi bi-person-plus me-1"></i><%= t('teachers.add') %>
      </a>
    </div>
  <% } else { %>
  <div class="table-responsive">
    <table class="table mb-0">
      <thead>
        <tr>
          <th><%= lang==='vi' ? 'Mã GV' : 'Code' %></th>
          <th><%= t('teachers.name') %></th>
          <th><%= t('teachers.phone') %></th>
          <th><%= t('teachers.specialty') %></th>
          <th><%= t('teachers.type') %></th>
          <th><%= t('teachers.hourly_rate') %></th>
          <th><%= t('common.status') %></th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% rows.forEach(tc => {
          const typeMap = {
            fulltime:  { lbl: lang==='vi' ? 'Cơ hữu' : 'Full-time', cls: 'badge-ongoing' },
            parttime:  { lbl: lang==='vi' ? 'Bán thời gian' : 'Part-time', cls: 'badge-planned' },
            freelance: { lbl: 'Freelance', cls: 'badge-inactive' },
          };
          const tm = typeMap[tc.teacher_type] || { lbl: tc.teacher_type, cls: 'badge-inactive' };
        %>
        <tr>
          <td><code style="font-size:12px;color:var(--ash)"><%= tc.teacher_code %></code></td>
          <td>
            <a href="/teachers/<%= tc.id %>" class="fw-semibold text-decoration-none" style="color:var(--ink)">
              <%= tc.full_name %>
            </a>
          </td>
          <td style="color:var(--ash)"><%= tc.phone || '—' %></td>
          <td>
            <div class="d-flex flex-wrap gap-1">
              <% (tc.specialtyArr || []).slice(0,3).forEach(s => { %>
                <span class="badge badge-ongoing" style="padding:3px 8px;font-size:11px"><%= s %></span>
              <% }) %>
              <% if ((tc.specialtyArr || []).length > 3) { %>
                <span class="badge badge-inactive" style="padding:3px 8px;font-size:11px">
                  +<%= tc.specialtyArr.length - 3 %>
                </span>
              <% } %>
              <% if (!(tc.specialtyArr || []).length) { %>
                <span style="color:var(--ash)">—</span>
              <% } %>
            </div>
          </td>
          <td><span class="badge <%= tm.cls %>" style="padding:4px 10px"><%= tm.lbl %></span></td>
          <td style="color:var(--ink);font-weight:600">
            <%= tc.hourly_rate > 0
              ? Number(tc.hourly_rate).toLocaleString('vi-VN') + ' ₫'
              : '—' %>
          </td>
          <td>
            <span class="badge <%= tc.status==='active' ? 'badge-active' : 'badge-inactive' %>"
                  style="padding:4px 10px">
              <%= tc.status==='active' ? (lang==='vi' ? 'Đang dạy' : 'Active') : (lang==='vi' ? 'Ngừng' : 'Inactive') %>
            </span>
          </td>
          <td class="text-end">
            <div class="d-flex justify-content-end gap-1">
              <a href="/teachers/<%= tc.id %>"      class="btn btn-sm btn-outline-secondary" title="View"><i class="bi bi-eye"></i></a>
              <a href="/teachers/<%= tc.id %>/edit" class="btn btn-sm btn-outline-secondary" title="Edit"><i class="bi bi-pencil"></i></a>
            </div>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
  <% } %>
</div>

<!-- Pagination -->
<% if (totalPages > 1) { %>
<nav class="d-flex justify-content-between align-items-center mt-4">
  <span class="small text-muted">
    <%= lang==='vi' ? `Trang ${page} / ${totalPages} — ${total} giáo viên` : `Page ${page} of ${totalPages} — ${total} teachers` %>
  </span>
  <ul class="pagination pagination-sm mb-0">
    <li class="page-item <%= page<=1 ? 'disabled':'' %>">
      <a class="page-link" href="?page=<%= page-1 %>&search=<%= search %>&status=<%= filterStatus %>&type=<%= filterType %>">
        <i class="bi bi-chevron-left"></i>
      </a>
    </li>
    <% for(let p=Math.max(1,page-2); p<=Math.min(totalPages,page+2); p++) { %>
      <li class="page-item <%= p===page?'active':'' %>">
        <a class="page-link" href="?page=<%= p %>&search=<%= search %>&status=<%= filterStatus %>&type=<%= filterType %>"><%= p %></a>
      </li>
    <% } %>
    <li class="page-item <%= page>=totalPages ? 'disabled':'' %>">
      <a class="page-link" href="?page=<%= page+1 %>&search=<%= search %>&status=<%= filterStatus %>&type=<%= filterType %>">
        <i class="bi bi-chevron-right"></i>
      </a>
    </li>
  </ul>
</nav>
<% } %>

<style>
.page-link { border-color:var(--hairline);color:var(--ink);font-size:13px }
.page-item.active .page-link { background:var(--rausch);border-color:var(--rausch); }
</style>
